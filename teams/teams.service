[Unit]
Description=Teams-Server
After=network.target

[Service]
ExecStart=/usr/bin/node /var/www/html/kasse/teams/teams.js
WorkingDirectory=/var/www/html/kasse/teams
Restart=always
User=dome2k3
Environment=NODE_ENV=production

# Logs direkt ins journalctl
StandardOutput=journal
StandardError=journal
SyslogIdentifier=kasse

[Install]
WantedBy=multi-user.target
